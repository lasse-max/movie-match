# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must never be committed.
#
# Both keys are read SERVER-SIDE ONLY (inside app/api/* route handlers via
# process.env). They are NOT prefixed with NEXT_PUBLIC_, so they are never
# bundled into client code or exposed to the browser.

# TMDB — movie metadata, genres, and watch-provider availability.
# Use the v4 Read Access Token (Settings → API → "API Read Access Token").
# Get one at https://www.themoviedb.org/settings/api
# Sent as: Authorization: Bearer <token>
TMDB_READ_ACCESS_TOKEN=

# Anthropic / Claude — used for the 2 taste-blend calls per session (added in a later step).
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
